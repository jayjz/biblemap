# ==============================================================================
# CYBERSECURITY & SECRETS (NEVER COMMIT)
# ==============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.cert
secrets.json
credentials.json
auth.json

# ==============================================================================
