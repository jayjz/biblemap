# ==============================================================================
# BibleMap - Comprehensive .gitignore
# Generated: 2026-05-17 - Codebase cleanup
# ==============================================================================

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp/
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ──────────────────────────────────────────────────────────────────
.next/
out/
build/
dist/

# ── Production Builds ────────────────────────────────────────────────────────
.vercel
.netlify

# ── Environment Variables (NEVER COMMIT SECRETS) ────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/

# ── Databases ────────────────────────────────────────────────────────────────
*.db
*.db-journal
*.sqlite
*.sqlite3
*.dump
*.sql
*.bak
/pgdata/
/postgres-data/
.DS_Store
Thumbs.db

# ── IDE & Editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
Icon
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Testing ──────────────────────────────────────────────────────────────────
/coverage
.nyc_output

# ── Misc ─────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
*.key
*.crt
*.cert
secrets.json
credentials.json
auth.json
.cache/
.parcel-cache/

# ── Data Files (Large Binaries) ──────────────────────────────────────────────
# Note: Public Parquet files in /public are intentionally tracked as they are
# required for the static export. Only ignore local data directories.
/data/
/raw-data/
*.parquet

# ── OS Generated ─────────────────────────────────────────────────────────────
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Temporary Files ──────────────────────────────────────────────────────────
*.tmp
*.temp
.cache/
temp/
tmp/
